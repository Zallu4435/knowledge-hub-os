                "overrides": []
            },
            "gridPos": {
                "h": 7,
                "w": 8,
                "x": 16,
                "y": 26
            },
            "id": 22,
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(http_requests_total{job=\"ai-service\",status_code=~\"5..\"}[5m]))",
                    "legendFormat": "5xx errors",
                    "refId": "A"
