{
    "$id": "https://knowledgehub.os/schemas/task.completed.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "TaskCompletedEvent",
    "type": "object",
    "properties": {
        "eventId": {
            "type": "string",
            "format": "uuid"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "data": {
            "type": "object",
            "properties": {
                "userId": {
                    "type": "string"
                },
                "goalTitle": {
                    "type": "string"
                },
                "taskTitle": {
                    "type": "string"
                }
            },
            "required": [
                "userId",
                "goalTitle",
                "taskTitle"
            ]
        }
    },
    "required": [
        "eventId",
        "timestamp",
        "data"
    ]
}