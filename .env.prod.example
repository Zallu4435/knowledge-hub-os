# ============================================================
# .env.prod.example — Production Environment Template
# ============================================================
# 1. Copy this file to .env on your Oracle VM:
#       cp .env.prod.example .env
# 2. Fill in every value below — never commit the filled .env
# 3. Generate secrets with:
#       openssl rand -base64 32        ← for JWT_SECRET
#       openssl rand -hex 32           ← alternative
# ============================================================

# ─────────────────────────────────────────────────────────────
# DATABASE — Neon Postgres (already cloud-hosted, keep as-is)
# ─────────────────────────────────────────────────────────────
DATABASE_URL='postgresql://<USER>:<PASSWORD>@<HOST>/<DB>?sslmode=require&pgbouncer=true'

# ─────────────────────────────────────────────────────────────
# MONGODB — MongoDB Atlas (already cloud-hosted, keep as-is)
# ─────────────────────────────────────────────────────────────
MONGO_URI='mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/?appName=<APP>'

# ─────────────────────────────────────────────────────────────
# AI — Google Gemini API key (keep as-is from .env)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY='<YOUR_GEMINI_API_KEY>'

# ─────────────────────────────────────────────────────────────
# JWT — MUST change in production!
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
JWT_SECRET='<GENERATE_WITH_OPENSSL_RAND_BASE64_32>'
JWT_EXPIRES_IN='1d'

# ─────────────────────────────────────────────────────────────
# KAFKA — Redpanda runs inside Docker, use container name
# ─────────────────────────────────────────────────────────────
KAFKA_BROKER_URL='redpanda:29092'

# ─────────────────────────────────────────────────────────────
# REDIS — runs inside Docker, use container name
# ─────────────────────────────────────────────────────────────
REDIS_URL='redis://redis:6379'

# ─────────────────────────────────────────────────────────────
# GITHUB — for docker-compose.prod.yml image tags
# ─────────────────────────────────────────────────────────────
GITHUB_ORG='<YOUR_GITHUB_USERNAME_OR_ORG>'

# ─────────────────────────────────────────────────────────────
# SERVICE PORTS — internal container ports, don't change
# ─────────────────────────────────────────────────────────────
PORT_API_GATEWAY=3000
PORT_AUTH_SERVICE=3001
PORT_GOAL_SERVICE=3002
PORT_AI_SERVICE=8000
PORT_FRONTEND=4000

# ─────────────────────────────────────────────────────────────
# CORS / URLs — replace <VM_IP_OR_DOMAIN> with your Oracle VM
# public IP, e.g. 129.154.200.123 or yourdomain.com
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS='http://<VM_IP_OR_DOMAIN>'

# If you added Nginx, all traffic goes through port 80:
NEXT_PUBLIC_API_GATEWAY_URL='http://<VM_IP_OR_DOMAIN>/api'
NEXT_PUBLIC_AUTH_URL='http://<VM_IP_OR_DOMAIN>/api/auth'
NEXT_PUBLIC_GOAL_SERVICE_URL='http://<VM_IP_OR_DOMAIN>/api/goals'
NEXT_PUBLIC_AI_SERVICE_URL='http://<VM_IP_OR_DOMAIN>/api/ai'

# ─────────────────────────────────────────────────────────────
# OTEL (set by docker-compose.yml already — leave as-is)
# ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT='http://jaeger:4318'
